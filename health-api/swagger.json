{
  "swagger": "2.0",
  "info": {
    "title": "Health API",
    "description": "API for managing medicines and ailments. POST, PUT and DELETE routes require authentication via Google OAuth.",
    "version": "1.0.0"
  },
  "host": "cse341-node-1-health-api.onrender.com",
  "basePath": "/",
  "schemes": ["https"],
  "securityDefinitions": {
    "OAuth2": {
      "type": "oauth2",
      "authorizationUrl": "https://accounts.google.com/o/oauth2/auth",
      "flow": "implicit",
      "scopes": {
        "profile": "Access your Google profile",
        "email": "Access your Google email"
      }
    }
  },
  "paths": {
    "/auth/login": {
      "get": {
        "summary": "Login with Google",
        "description": "Redirects to Google OAuth login page",
        "responses": {
          "302": {
            "description": "Redirects to Google login"
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "summary": "Logout",
        "description": "Logs the user out",
        "responses": {
          "302": {
            "description": "Redirects after logout"
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "summary": "Get logged in user profile",
        "description": "Returns the profile of the currently logged in user",
        "responses": {
          "200": {
            "description": "User profile returned successfully"
          },
          "401": {
            "description": "Not logged in"
          }
        }
      }
    },
    "/medicines": {
      "get": {
        "summary": "Get all medicines",
        "description": "Returns a list of all medicines",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      },
      "post": {
        "summary": "Create a new medicine",
        "description": "Adds a new medicine to the database. Requires authentication.",
        "security": [{"OAuth2": ["profile", "email"]}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Medicine"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Medicine created successfully"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized - must be logged in"
          }
        }
      }
    },
    "/medicines/{id}": {
      "get": {
        "summary": "Get a single medicine",
        "description": "Returns a single medicine by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "404": {
            "description": "Medicine not found"
          }
        }
      },
      "put": {
        "summary": "Update a medicine",
        "description": "Updates an existing medicine by ID. Requires authentication.",
        "security": [{"OAuth2": ["profile", "email"]}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Medicine"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Medicine updated successfully"
          },
          "401": {
            "description": "Unauthorized - must be logged in"
          },
          "404": {
            "description": "Medicine not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a medicine",
        "description": "Deletes a medicine by ID. Requires authentication.",
        "security": [{"OAuth2": ["profile", "email"]}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Medicine deleted successfully"
          },
          "401": {
            "description": "Unauthorized - must be logged in"
          },
          "404": {
            "description": "Medicine not found"
          }
        }
      }
    },
    "/ailments": {
      "get": {
        "summary": "Get all ailments",
        "description": "Returns a list of all ailments",
        "produces": ["application/json"],
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      },
      "post": {
        "summary": "Create a new ailment",
        "description": "Adds a new ailment to the database. Requires authentication.",
        "security": [{"OAuth2": ["profile", "email"]}],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Ailment"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Ailment created successfully"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthorized - must be logged in"
          }
        }
      }
    },
    "/ailments/{id}": {
      "get": {
        "summary": "Get a single ailment",
        "description": "Returns a single ailment by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "404": {
            "description": "Ailment not found"
          }
        }
      },
      "put": {
        "summary": "Update an ailment",
        "description": "Updates an existing ailment by ID. Requires authentication.",
        "security": [{"OAuth2": ["profile", "email"]}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Ailment"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ailment updated successfully"
          },
          "401": {
            "description": "Unauthorized - must be logged in"
          },
          "404": {
            "description": "Ailment not found"
          }
        }
      },
      "delete": {
        "summary": "Delete an ailment",
        "description": "Deletes an ailment by ID. Requires authentication.",
        "security": [{"OAuth2": ["profile", "email"]}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Ailment deleted successfully"
          },
          "401": {
            "description": "Unauthorized - must be logged in"
          },
          "404": {
            "description": "Ailment not found"
          }
        }
      }
    }
  },
  "definitions": {
    "Medicine": {
      "type": "object",
      "required": ["name", "dosage", "manufacturer", "sideEffects", "price", "prescription", "category", "description"],
      "properties": {
        "name": {"type": "string"},
        "dosage": {"type": "string"},
        "manufacturer": {"type": "string"},
        "sideEffects": {"type": "string"},
        "price": {"type": "number"},
        "prescription": {"type": "boolean"},
        "category": {"type": "string"},
        "description": {"type": "string"}
      }
    },
    "Ailment": {
      "type": "object",
      "required": ["name", "symptoms", "description", "causes", "severity", "contagious", "treatment"],
      "properties": {
        "name": {"type": "string"},
        "symptoms": {"type": "string"},
        "description": {"type": "string"},
        "causes": {"type": "string"},
        "severity": {"type": "string"},
        "contagious": {"type": "boolean"},
        "treatment": {"type": "string"}
      }
    }
  }
}